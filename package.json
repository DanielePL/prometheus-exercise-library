{
  "name": "prometheus-library-server",
  "version": "1.0.0",
  "description": "Server for Prometheus Exercise Library",
  "main": "server/src/index.js",
  "scripts": {
    "start": "node server/src/index.js",
    "dev": "nodemon server/src/index.js",
    "dev-all": "concurrently \"npm run dev\" \"cd client && npm start\"",
    "client": "cd client && npm start",
    "build": "cd client && npm install && npm run build && cd .. && cd server && npm install",
    "verify": "node verify-build.js",
    "heroku-postbuild": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "crawl": "node crawlers/index.js",
    "crawl:historical": "node crawlers/index.js --historical",
    "schedule": "node -e 'require(\"./crawlers/scheduler\").initScheduler()'"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "concurrently": "^8.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.15.0",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "private": true
}
